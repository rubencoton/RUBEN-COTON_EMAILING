PORT=3000
# PostgreSQL eliminado (refactor 2026-04-25). Persistencia 100% local
# en /app/data/store.json + backup auto a Drive cada hora.
# DATABASE_URL/DATABASE_* vars se ignoran si están definidas.
APP_ACCESS_PASSWORD=+artesbuho26
APP_ACCESS_SECRET=cambia-este-secreto-en-produccion
APP_AUTH_COOKIE_SECURE=auto
MAIL_TRANSPORT_MODE=direct
BOTAVIA_API_BASE_URL=https://api.botavia.com
BOTAVIA_API_KEY=tu_api_key_botavia
BOTAVIA_SEND_PATH=/send
BOTAVIA_HEALTH_PATH=/health
SMTP_HOST=smtp.tu-servidor.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=usuario_smtp
SMTP_PASS=password_smtp
SMTP_FROM_NAME=Artes Buho Management
SMTP_FROM_EMAIL=booking@artesbuhomanagement.com
SMTP_REPLY_TO=booking@artesbuhomanagement.com
SMTP_REQUIRE_TLS=false
SMTP_SKIP_TLS_VERIFY=false
MAIL_RATE_LIMIT_PER_MIN=5
MAIL_MAX_RETRIES=1
