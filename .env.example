PORT=3000
APP_ACCESS_PASSWORD=+ruben93
APP_ACCESS_SECRET=cambia-este-secreto-en-produccion
APP_AUTH_COOKIE_SECURE=auto

# Modo de envio: gmail-api (recomendado, Workspace) | direct | smtp | botavia
MAIL_TRANSPORT_MODE=gmail-api
SMTP_FROM_NAME=RUBEN COTON
SMTP_FROM_EMAIL=manager@rubencoton.com
SMTP_REPLY_TO=manager@rubencoton.com
SMTP_USER=manager@rubencoton.com
MAIL_RATE_LIMIT_PER_MIN=5
MAIL_MAX_RETRIES=1
MAIL_HISTORY_LIMIT=200
MAIL_UNSUBSCRIBE_BASE_URL=https://emailing.rubencoton.com/unsubscribe

# OAuth Google (manager@rubencoton.com) — Gmail API + Drive + Sheets
GOOGLE_OAUTH_CLIENT_ID=tu-client-id.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=GOCSPX-...
GOOGLE_OAUTH_REFRESH_TOKEN=1//0...
GOOGLE_REFRESH_TOKEN=1//0...
GOOGLE_OAUTH_REDIRECT_URI=http://localhost

# Drive: carpeta raiz para archivado de campañas
DRIVE_ROOT_FOLDER_ID=1HNxywrecpNWcXgkvyezmbNFD0ROkB8tI

# Sheets sync (L-V 8-20h Madrid)
SHEETS_SYNC_INTERVAL_MIN=30
SHEETS_AUTOSYNC_ENABLED=true

# Modo direct (fallback si quieres bypass Gmail API): requiere DKIM publicado
# MAIL_DIRECT_HOSTNAME=mailer.rubencoton.com
# MAIL_DKIM_DOMAIN=rubencoton.com
# MAIL_DKIM_SELECTOR=mail
# MAIL_DKIM_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\nTU_CLAVE\n-----END PRIVATE KEY-----

# ────────────────────────────────────────────────────────────
# ANTI-SPAM / DELIVERABILITY (P0 audit 2026-05-05)
# ────────────────────────────────────────────────────────────

# Tracking HMAC: secreto persistente para firmar URLs de pixel/click.
# OBLIGATORIO en producción. Sin esto se autogenera en memoria y cada
# reinicio invalida los clicks/aperturas de emails ya enviados.
# Generar con:  openssl rand -hex 32
TRACKING_SECRET=cambiame-en-produccion-min-16-chars-recomendado-32-hex

# Tracking enforce: 1 = rechaza URLs sin firma o con firma inválida.
# 0 = modo permisivo (default, registra pero marca signed:false).
# Recomendado en prod: 1
TRACKING_REQUIRE_HMAC=1

# Writeback Sheets Merge Status: debounce flush en ms.
# 1500 ms = casi tiempo real (ver columna actualizada al instante).
# Subir a 30000 si tienes problemas con rate-limit Google Sheets.
WRITEBACK_FLUSH_MS=1500

# Bandeja principal Gmail: omite headers que activan tab "Promociones"
# (List-Id, Precedence, Auto-Submitted). Feedback-ID se mantiene siempre.
MAIL_DELIVER_TO_PRIMARY=true

# ────────────────────────────────────────────────────────────
# DNS REQUERIDO en rubencoton.com (no son env vars, son registros DNS):
#
#  SPF      TXT  @          v=spf1 include:_spf.google.com ~all
#  DKIM     TXT  google._domainkey   (publicado por Google Workspace)
#  DMARC    TXT  _dmarc     v=DMARC1; p=quarantine; rua=mailto:postmaster@rubencoton.com; pct=100
#
# Verificar:  dig TXT _dmarc.rubencoton.com
# Si DMARC está en p=none, cualquier spoofing del dominio pasa libre y la
# reputación cae lentamente. P0 = pasar a quarantine y monitorizar 7 días.
# ────────────────────────────────────────────────────────────
